{
  "name": "ledgerly",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:backend --workspace @ledgerly/backend",
    "dev:backend": "npm run dev --workspace @ledgerly/backend",
    "dev:frontend": "npm run dev --workspace @ledgerly/frontend",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema apps/backend/prisma/schema.prisma",
    "seed": "tsx apps/backend/src/seed.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "jest": "^29.7.0",
    "prisma": "^6.1.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
